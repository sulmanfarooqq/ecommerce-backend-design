<footer class="footer"> <%# Start of the comprehensive site footer region %>
  <div class="container"> <%# Standard container for information alignment and spacing %>
    
    <div class="footer-grid"> <%# multi-column grid for organized site information and external links %>
      
      <!-- Brand & Description Column -->
      <div class="footer-col brand-col"> <%# Primary column for brand identity and summary text %>
        <img src="/img.jpg" alt="Brand Logo" style="height: 40px; margin-bottom: 1.5rem;"> <%# Display brand logo again for footer identity %>
        <p style="color: var(--gray-800); margin-bottom: 1.5rem; font-size: 0.95rem; line-height: 1.6;"> <%# Summary paragraph about the company purpose %>
          Best information about the company gies here but now lorem ipsum is for dummy text.
        </p> <%# End of company description %>
        <div class="social-links" style="display: flex; gap: 0.8rem;"> <%# Container for social media icon links %>
          <a href="#" class="social-icon" style="background: var(--gray-600); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; items-center; justify-content: center; font-size: 0.9rem;"><i class="fab fa-facebook-f"></i></a> <%# Facebook profile link %>
          <a href="#" class="social-icon" style="background: var(--gray-600); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; items-center; justify-content: center; font-size: 0.9rem;"><i class="fab fa-twitter"></i></a> <%# Twitter profile link %>
          <a href="#" class="social-icon" style="background: var(--gray-600); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; items-center; justify-content: center; font-size: 0.9rem;"><i class="fab fa-linkedin-in"></i></a> <%# LinkedIn profile link %>
          <a href="#" class="social-icon" style="background: var(--gray-600); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; items-center; justify-content: center; font-size: 0.9rem;"><i class="fab fa-instagram"></i></a> <%# Instagram profile link %>
          <a href="#" class="social-icon" style="background: var(--gray-600); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; items-center; justify-content: center; font-size: 0.9rem;"><i class="fab fa-youtube"></i></a> <%# YouTube channel link %>
        </div> <%# End of social links cluster %>
      </div> <%# End of brand info column %>

      <!-- Information Link Columns -->
      <div class="footer-col"> <%# Column for corporate information links %>
        <h4 style="margin-bottom: 1.5rem;">About</h4> <%# Header for corporate links group %>
        <ul style="color: var(--gray-600); font-size: 0.9rem; display: flex; flex-direction: column; gap: 0.8rem;"> <%# Vertical list of corporate page links %>
          <li><a href="#">About Us</a></li> <%# History and mission page %>
          <li><a href="#">Find store</a></li> <%# Physical location finder %>
          <li><a href="#">Categories</a></li> <%# Product taxonomy overview %>
          <li><a href="#">Blogs</a></li> <%# Company knowledge base %>
        </ul> <%# End of About links list %>
      </div> <%# End of About column %>

      <div class="footer-col"> <%# Column for business and partnership links %>
        <h4 style="margin-bottom: 1.5rem;">Partnership</h4> <%# Header for partnership links group %>
        <ul style="color: var(--gray-600); font-size: 0.9rem; display: flex; flex-direction: column; gap: 0.8rem;"> <%# Vertical list of business collaboration links %>
          <li><a href="#">About Us</a></li> <%# B2B partnership details %>
          <li><a href="#">Find store</a></li> <%# Partner store directory %>
          <li><a href="#">Categories</a></li> <%# Partner product categories %>
          <li><a href="#">Blogs</a></li> <%# Partner success stories %>
        </ul> <%# End of Partnership links list %>
      </div> <%# End of Partnership column %>

      <div class="footer-col"> <%# Column for logistical and help information links %>
        <h4 style="margin-bottom: 1.5rem;">Information</h4> <%# Header for support links group %>
        <ul style="color: var(--gray-600); font-size: 0.9rem; display: flex; flex-direction: column; gap: 0.8rem;"> <%# Vertical list of customer service and shipping links %>
          <li><a href="#">Help Center</a></li> <%# Support and FAQ access %>
          <li><a href="#">Money Refund</a></li> <%# Policy on returns and refunds %>
          <li><a href="#">Shipping</a></li> <%# Shipping rates and estimated times %>
          <li><a href="#">Contact us</a></li> <%# Customer support contact details %>
        </ul> <%# End of Information links list %>
      </div> <%# End of Information column %>

      <div class="footer-col"> <%# Column for user-centric account links %>
        <h4 style="margin-bottom: 1.5rem;">For users</h4> <%# Header for account-related links group %>
        <ul style="color: var(--gray-600); font-size: 0.9rem; display: flex; flex-direction: column; gap: 0.8rem;"> <%# Vertical list of account management links %>
          <li><a href="/login">Login</a></li> <%# Account access page %>
          <li><a href="/signup">Register</a></li> <%# New account creation page %>
          <li><a href="#">Settings</a></li> <%# Profile preference management %>
          <li><a href="#">My Orders</a></li> <%# Order history tracking %>
        </ul> <%# End of For users links list %>
      </div> <%# End of For users column %>

      <!-- Mobile App Download Column -->
      <div class="footer-col"> <%# Column for encouraging mobile app usage %>
        <h4 style="margin-bottom: 1.5rem;">Get app</h4> <%# Header for app download actions %>
        <div style="display: flex; flex-direction: column; gap: 1rem;"> <%# Stack download store images vertically %>
          <a href="#"><img src="https://upload.wikimedia.org/wikipedia/commons/3/3c/Download_on_the_App_Store_Badge.svg" alt="App Store" style="width: 120px;"></a> <%# Apple App Store store link %>
          <a href="#"><img src="https://upload.wikimedia.org/wikipedia/commons/7/78/Google_Play_Store_badge_EN.svg" alt="Google Play" style="width: 120px;"></a> <%# Google Play store link %>
        </div> <%# End of app download cluster %>
      </div> <%# End of app column %>

    </div> <!--/ .footer-grid -->

  </div> <!--/ .container -->

  <!-- Bottom Copyright & Localization Bar -->
  <div style="background-color: var(--gray-300); padding: 1.5rem 0; margin-top: 3rem;"> <%# Subtle bar for legal and bottom-level settings %>
    <div class="container" style="display: flex; justify-content: space-between; align-items: center; color: var(--gray-800); font-size: 0.9rem;"> <%# Align copyright and settings details horizontally %>
      <p>© 2023 Ecommerce.</p> <%# Legal copyright ownership statement %>
      <div style="display: flex; align-items: center; gap: 0.5rem;"> <%# localization indicator for final page footer %>
        <img src="https://flagcdn.com/w20/us.png" alt="US" style="width: 20px;"> English <i class="fas fa-chevron-up"></i> <%# Language preference display with icon %>
      </div> <%# End of bottom localization item %>
    </div> <%# End of bottom bar content alignment %>
  </div> <%# End of bottom gray bar area %>

</footer> <%# End of the complete high-fidelity site footer section %>

/*
SUMMARY:
- This file implements a professional, multi-column footer as seen in high-end ecommerce designs.
- It includes localized information columns, social media integration, and mobile app download links.
- It uses a clear visual hierarchy and consistent brand styling to anchor every page in the application.
*/
