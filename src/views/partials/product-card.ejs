<div class="product-card">

  <a href="/products/<%= product._id %>" class="product-image-link">
    <div class="product-image-container">
      <img src="<%= product.image && product.image.startsWith('http') ? product.image : '/img.jpg' %>" alt="<%= product.name %>" class="product-image">
    </div>
  </a>

  <div class="product-info">

    <div class="product-price">
      $<%= product.price.toFixed(2) %>
    </div>

    <div class="product-rating" style="color: var(--warning-color); font-size: 0.85rem; margin-bottom: 0.5rem;">

      <% for(let i = 1; i <= 5; i++) { %>
        <i class="<%= i <= Math.round(product.rating) ? 'fas' : 'far' %> fa-star"></i>
      <% } %>
      <span style="color: var(--gray-600); margin-left: 0.3rem;"><%= product.rating %></span>
    </div>

    <a href="/products/<%= product._id %>" class="product-title">
      <%= product.name %>
    </a>

    <% if (product.featured) { %>
      <span class="badge-featured" style="margin-top: 0.5rem; display: inline-block;">Featured</span>
    <% } %>

  </div>

</div>

/*
SUMMARY:
- This file implements a reusable, high-fidelity product card component as shown in the web prototype.
- It includes price prominence, star ratings, and a clear visual hierarchy for the product title.
- It uses conditional logic for fallback images and badge displays to maintain UI consistency.
*/

