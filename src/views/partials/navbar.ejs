<header class="header">
  <div class="container">

<div class="navbar-top">

<a href="/" class="brand">
        <img src="/img.jpg" alt="Brand Logo" style="height: 40px; width: auto;">
      </a>

<div class="nav-search">
        <input type="text" placeholder="Search for products...">
        <select class="form-control" style="width: 150px; border: none; border-left: 1px solid var(--gray-400); border-radius: 0;">
          <option>All category</option>
          <option>Electronics</option>
          <option>Home & Garden</option>
        </select>
        <button class="btn btn-primary" style="padding: 0 1.5rem; border-radius: 0;">Search</button>
      </div>

<div class="nav-actions">
        <a href="/login" class="nav-action-item">
          <i class="fas fa-user"></i>
          <span>Profile</span>
        </a>
        <a href="#" class="nav-action-item">
          <i class="fas fa-comment-dots"></i>
          <span>Message</span>
        </a>
        <a href="#" class="nav-action-item">
          <i class="fas fa-heart"></i>
          <span>Orders</span>
        </a>
        <a href="/cart" class="nav-action-item">
          <i class="fas fa-shopping-cart"></i>
          <span>My cart</span>
        </a>
      </div>

    </div>

  </div>
</header>

<nav class="navbar-bottom">
  <div class="container" style="display: flex; justify-content: space-between; align-items: center;">

    <div class="nav-menu">
      <a href="/products" style="display: flex; align-items: center; gap: 0.5rem;">
        <i class="fas fa-bars"></i> All category
      </a>
      <a href="/products?featured=true">Hot offers</a>
      <a href="#">Gift boxes</a>
      <a href="#">Projects</a>
      <a href="#">Menu item</a>
      <a href="#">Help</a>
    </div>

    <div class="nav-settings" style="display: flex; gap: 1.5rem; font-size: 0.9rem; font-weight: 500;">
      <div class="setting-item">English, USD <i class="fas fa-chevron-down"></i></div>
      <div class="setting-item">Ship to <img src="https://flagcdn.com/w20/de.png" alt="DE" style="display: inline; vertical-align: middle; margin-left: 5px;"> <i class="fas fa-chevron-down"></i></div>
    </div>

  </div>
</nav>

<div class="container" style="margin-top: 1rem;">
  <%- include('./alerts') %>
</div>

/*
SUMMARY:
- This file implements the dual-bar navigation system shown in the professional prototype.
- The top bar handles search, branding, and user status, while the bottom bar handles categories and localization.
- It uses FontAwesome for iconography and Flexbox for precise multi-element alignment across desktop viewports.
*/

