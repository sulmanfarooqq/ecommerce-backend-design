<% if (totalPages > 1) { %>
  <div class="pagination" style="display: flex; background: var(--white); border: 1px solid var(--gray-400); border-radius: 4px; overflow: hidden;">

<a href="<%= baseUrl %>?page=<%= currentPage - 1 %>"
       class="pagination-btn <%= currentPage === 1 ? 'disabled' : '' %>"
       style="padding: 0.6rem 1rem; border-right: 1px solid var(--gray-400); color: <%= currentPage === 1 ? 'var(--gray-500)' : 'var(--dark-color)' %>; cursor: <%= currentPage === 1 ? 'not-allowed' : 'pointer' %>;">
      <i class="fas fa-chevron-left"></i>
    </a>

<% for (let i = 1; i <= totalPages; i++) { %>
      <a href="<%= baseUrl %>?page=<%= i %>"
         class="pagination-num <%= currentPage === i ? 'active' : '' %>"
         style="padding: 0.6rem 1.2rem; border-right: 1px solid var(--gray-400); font-weight: 500;
                background: <%= currentPage === i ? 'var(--gray-300)' : 'var(--white)' %>;
                color: <%= currentPage === i ? 'var(--dark-color)' : 'var(--gray-600)' %>;">
        <%= i %>
      </a>
    <% } %>

<a href="<%= baseUrl %>?page=<%= currentPage + 1 %>"
       class="pagination-btn <%= currentPage === totalPages ? 'disabled' : '' %>"
       style="padding: 0.6rem 1rem; color: <%= currentPage === totalPages ? 'var(--gray-500)' : 'var(--primary-color)' %>; cursor: <%= currentPage === totalPages ? 'not-allowed' : 'pointer' %>;">
      <i class="fas fa-chevron-right"></i>
    </a>

  </div>
<% } %>

/*
SUMMARY:
- This file implements a premium, organized pagination component as seen in professional web designs.
- It includes active page highlighting, directional icon controls, and a clean, responsive layout structure.
- It ensures users can intuitively navigate through large product catalogs with clear visual feedback.
*/

