<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? `${title} | ShopEase` : 'ShopEase | Premium Ecommerce' %></title>

<link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/responsive.css">

  <%- typeof extraCSS !== 'undefined' ? extraCSS : '' %>
</head>
<body>

  <%- include('../partials/navbar') %>

  <main class="container" style="min-height: 80vh; padding-top: 2rem;">
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

<script src="/js/main.js"></script>

<%- typeof extraJS !== 'undefined' ? extraJS : '' %>

</body>
</html>

/*
SUMMARY:
- This file serves as the master layout for every page in the application.
- It includes all the necessary meta tags, stylesheets, and scripts to ensure consistency.
- It uses EJS partials for the navbar and footer and injects page-specific content into the `<main>` tag.
*/

