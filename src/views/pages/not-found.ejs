<%- layout('layouts/main') %>

<div style="text-align: center; padding: 7rem 0;">
  <div style="font-size: 8rem; font-weight: 800; color: #eee; line-height: 1; margin-bottom: 1rem;">404</div>

  <h1 style="font-size: 2.5rem; margin-bottom: 1rem; color: var(--primary-color);">Page Not Found</h1>
  <p style="font-size: 1.2rem; color: #666; margin-bottom: 3rem;">
    Sorry, the page you are looking for at <br>
    <strong style="color: var(--accent-color);"><%= url %></strong> <br>
    does not exist or has been moved to a new location.
  </p>

  <div style="margin-top: 2rem;">
    <a href="/" class="btn btn-primary" style="padding: 12px 30px;">Back to Homepage</a>
  </div>

  <div style="margin-top: 4rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; max-width: 600px; margin-left: auto; margin-right: auto;">
    <a href="/products" style="padding: 1rem; border: 1px solid #eee; border-radius: 8px;">Browse Products</a>
    <a href="/login" style="padding: 1rem; border: 1px solid #eee; border-radius: 8px;">User Login</a>
    <a href="/signup" style="padding: 1rem; border: 1px solid #eee; border-radius: 8px;">Create Account</a>
  </div>
</div>

/*
SUMMARY:
- This page handles situations where a user attempts to access a URL that doesn't correspond to any route.
- It provides a polite and helpful explanation of why the page is missing along with the original requested URL.
- It includes multiple links to other important parts of the store to keep the user from getting frustrated.
*/

