<%- contentFor('body') %>

<h2 style="margin-bottom: 2rem;">My cart (3)</h2>

<div style="display: grid; grid-template-columns: 1fr 280px; gap: 2rem;">

<div>

    <div class="section-white" style="margin-bottom: 2rem; padding: 1.5rem 0;">

<div style="display: flex; gap: 1.5rem; padding: 1rem 1.5rem; border-bottom: 1px solid var(--gray-400);">
        <img src="/img.jpg" style="width: 80px; height: 80px; border: 1px solid var(--gray-400); border-radius: 4px; object-fit: contain;">
        <div style="flex-grow: 1;">
          <div style="display: flex; justify-content: space-between; align-items: flex-start;">
            <div>
              <h4 style="margin-bottom: 0.3rem;">T-shirts with multiple colors, for men and lady</h4>
              <p style="color: var(--gray-600); font-size: 0.9rem;">Size: medium, Color: blue, Material: Plastic<br>Seller: Artel Market</p>
            </div>
            <div style="font-weight: 700;">$78.99</div>
          </div>
          <div style="display: flex; gap: 1rem; margin-top: 1rem;">
            <button class="btn btn-secondary" style="padding: 0.3rem 0.8rem; border-color: var(--accent-color); color: var(--accent-color); font-size: 0.85rem;">Remove</button>
            <button class="btn btn-secondary" style="padding: 0.3rem 0.8rem; font-size: 0.85rem;">Save for later</button>
          </div>
        </div>
        <div style="align-self: center;">
          <select class="form-control" style="width: 80px; padding: 0.3rem;">
            <option>Qty: 9</option>
          </select>
        </div>
      </div>

<div style="display: flex; justify-content: space-between; padding: 1rem 1.5rem;">
        <a href="/products" class="btn btn-primary" style="padding: 0.6rem 1.5rem;"><i class="fas fa-arrow-left"></i> Back to shop</a>
        <button class="btn btn-secondary" style="padding: 0.6rem 1.5rem;">Remove all</button>
      </div>

    </div>

<div style="display: flex; gap: 2rem; margin-top: 2rem;">
      <div style="display: flex; align-items: center; gap: 1rem;">
        <i class="fas fa-lock" style="font-size: 1.5rem; color: var(--gray-600);"></i>
        <div><span style="font-weight: 600;">Secure payment</span><br><small style="color: var(--gray-600);">Have you ever finally just</small></div>
      </div>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <i class="fas fa-comment-dots" style="font-size: 1.5rem; color: var(--gray-600);"></i>
        <div><span style="font-weight: 600;">Customer support</span><br><small style="color: var(--gray-600);">Have you ever finally just</small></div>
      </div>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <i class="fas fa-truck" style="font-size: 1.5rem; color: var(--gray-600);"></i>
        <div><span style="font-weight: 600;">Free delivery</span><br><small style="color: var(--gray-600);">Have you ever finally just</small></div>
      </div>
    </div>

  </div>

<aside>

    <div class="section-white" style="margin-bottom: 1.5rem;">
      <label style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem;">Have a coupon?</label>
      <div style="display: flex; border: 1px solid var(--gray-400); border-radius: var(--border-radius); overflow: hidden;">
        <input type="text" placeholder="Add coupon" style="border: none; padding: 0.6rem; width: 100%; outline: none;">
        <button class="btn btn-secondary" style="border: none; border-left: 1px solid var(--gray-400); border-radius: 0; color: var(--primary-color);">Apply</button>
      </div>
    </div>

    <div class="section-white">
      <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--gray-800);">
        <span>Subtotal:</span> <span>$1403.97</span>
      </div>
      <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--accent-color);">
        <span>Discount:</span> <span>- $60.00</span>
      </div>
      <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--gray-400); padding-bottom: 1rem; margin-bottom: 1rem; font-size: 0.95rem; color: var(--success-color);">
        <span>Tax:</span> <span>+ $14.00</span>
      </div>
      <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 700;">
        <span>Total:</span> <span>$1357.97</span>
      </div>
      <button class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem; background: var(--success-color);">Checkout</button>

      <div style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.5rem;">
        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" style="height: 20px;">
        <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" style="height: 20px;">
        <img src="https://upload.wikimedia.org/wikipedia/commons/5/5a/Visa_2021.svg" style="height: 20px;">
        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b0/Apple_Pay_logo.svg" style="height: 20px;">
      </div>
    </div>

  </aside>

</div>

<section style="margin-top: 5rem;">
  <h3 style="margin-bottom: 1.5rem;">Saved for later</h3>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem;">
    <% products.slice(0, 4).forEach(product => { %>
      <%- include('../partials/product-card', { product }) %>
    <% }); %>
  </div>
</section>

/*
SUMMARY:
- This file implements a high-fidelity shopping cart experience based on the professional prototype mockups.
- It features a multi-column layout with detailed item controls, service trust badges, and a comprehensive order summary sidebar.
- It provides a production-ready interface that focuses on user conversion and brand consistency across desktop viewports.
*/

