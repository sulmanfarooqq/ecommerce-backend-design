<%- contentFor('body') %> <%# Start of the specific content for the shopping cart layout %>

<h2 style="margin-bottom: 2rem;">My cart (3)</h2> <%# Section header with dynamic item count representation %>

<div style="display: grid; grid-template-columns: 1fr 280px; gap: 2rem;"> <%# primary two-column layout for the cart checkout experience %>

  <!-- Left: Cart Items & Trust Badges -->
  <div> <%# Main container for the list of added product items and service guarantees %>

    <div class="section-white" style="margin-bottom: 2rem; padding: 1.5rem 0;"> <%# Container for the individual product entries in the cart list %>
      
      <!-- Cart Item Entry -->
      <%# Mocking current items for high-fidelity representation as requested by the mockup %>
      <div style="display: flex; gap: 1.5rem; padding: 1rem 1.5rem; border-bottom: 1px solid var(--gray-400);"> <%# individual row for a specific cart product %>
        <img src="/img.jpg" style="width: 80px; height: 80px; border: 1px solid var(--gray-400); border-radius: 4px; object-fit: contain;"> <%# product thumbnail representation %>
        <div style="flex-grow: 1;"> <%# information area for item name and metadata %>
          <div style="display: flex; justify-content: space-between; align-items: flex-start;"> <%# Header info area with price prominence %>
            <div>
              <h4 style="margin-bottom: 0.3rem;">T-shirts with multiple colors, for men and lady</h4> <%# example item title from mockup %>
              <p style="color: var(--gray-600); font-size: 0.9rem;">Size: medium, Color: blue, Material: Plastic<br>Seller: Artel Market</p> <%# example metadata and seller attribution labels %>
            </div>
            <div style="font-weight: 700;">$78.99</div> <%# individual item unit price display %>
          </div> <%# End of item header area %>
          <div style="display: flex; gap: 1rem; margin-top: 1rem;"> <%# controls area for quantity and removal actions %>
            <button class="btn btn-secondary" style="padding: 0.3rem 0.8rem; border-color: var(--accent-color); color: var(--accent-color); font-size: 0.85rem;">Remove</button> <%# destructive action to delete item from cart %>
            <button class="btn btn-secondary" style="padding: 0.3rem 0.8rem; font-size: 0.85rem;">Save for later</button> <%# non-destructive action to move item to favorites %>
          </div> <%# End of item controls cluster %>
        </div> <%# End of item info area %>
        <div style="align-self: center;"> <%# quantity selector area for the cart entry %>
          <select class="form-control" style="width: 80px; padding: 0.3rem;"> <%# Dropdown for selecting item count %>
            <option>Qty: 9</option> <%# example quantity value from mockup %>
          </select> <%# End of quantity dropdown %>
        </div> <%# End of quantity selector area %>
      </div> <!--/ .cart-item -->

      <!-- Footer Actions for Cart List -->
      <div style="display: flex; justify-content: space-between; padding: 1rem 1.5rem;"> <%# alignment bar for global cart list actions %>
        <a href="/products" class="btn btn-primary" style="padding: 0.6rem 1.5rem;"><i class="fas fa-arrow-left"></i> Back to shop</a> <%# link for returning to product discovery results %>
        <button class="btn btn-secondary" style="padding: 0.6rem 1.5rem;">Remove all</button> <%# global destructive action to clear entire cart state %>
      </div> <!--/ .cart-footer-actions -->

    </div> <!--/ .section-white (cart list) -->

    <!-- Trust/Guarantee Badges -->
    <div style="display: flex; gap: 2rem; margin-top: 2rem;"> <%# cluster for service quality indicators shown in the mockup area %>
      <div style="display: flex; align-items: center; gap: 1rem;"> <%# individual service badge entry for payment security %>
        <i class="fas fa-lock" style="font-size: 1.5rem; color: var(--gray-600);"></i> <%# FontAwesome icon for security representation %>
        <div><span style="font-weight: 600;">Secure payment</span><br><small style="color: var(--gray-600);">Have you ever finally just</small></div> <%# label and brief meta subtext for the badge %>
      </div> <%# End of security badge %>
      <div style="display: flex; align-items: center; gap: 1rem;"> <%# individual service badge entry for support quality %>
        <i class="fas fa-comment-dots" style="font-size: 1.5rem; color: var(--gray-600);"></i> <%# FontAwesome icon for support representation %>
        <div><span style="font-weight: 600;">Customer support</span><br><small style="color: var(--gray-600);">Have you ever finally just</small></div> <%# label and brief meta subtext for the badge %>
      </div> <%# End of support badge %>
      <div style="display: flex; align-items: center; gap: 1rem;"> <%# individual service badge entry for shipping efficiency %>
        <i class="fas fa-truck" style="font-size: 1.5rem; color: var(--gray-600);"></i> <%# FontAwesome icon for shipping representation %>
        <div><span style="font-weight: 600;">Free delivery</span><br><small style="color: var(--gray-600);">Have you ever finally just</small></div> <%# label and brief meta subtext for the badge %>
      </div> <%# End of delivery badge %>
    </div> <!--/ .trust-badges -->

  </div> <!--/ .left-column -->

  <!-- Right: Sidebar Order Summary & Checkout -->
  <aside> <%# Sidebar for cumulative financial data and primary conversion trigger actions %>
    
    <div class="section-white" style="margin-bottom: 1.5rem;"> <%# Container for coupon application system %>
      <label style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem;">Have a coupon?</label> <%# text engagement for discount input %>
      <div style="display: flex; border: 1px solid var(--gray-400); border-radius: var(--border-radius); overflow: hidden;"> <%# composite input and button group for coupon code triggers %>
        <input type="text" placeholder="Add coupon" style="border: none; padding: 0.6rem; width: 100%; outline: none;"> <%# text entry for coupon code sequence %>
        <button class="btn btn-secondary" style="border: none; border-left: 1px solid var(--gray-400); border-radius: 0; color: var(--primary-color);">Apply</button> <%# trigger to validate coupon entry logic %>
      </div> <%# End of coupon input group area %>
    </div> <!--/ .coupon-box -->

    <div class="section-white"> <%# Container for cumulative price breakdown and checkout execution %>
      <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--gray-800);"> <%# subtotals label and value row before discounts %>
        <span>Subtotal:</span> <span>$1403.97</span> <%# cumulative individual item cost representation %>
      </div> <%# End of subtotal row %>
      <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.95rem; color: var(--accent-color);"> <%# discount label and value row showing customer savings %>
        <span>Discount:</span> <span>- $60.00</span> <%# subtraction value from applied promotions %>
      </div> <%# End of discount row %>
      <div style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--gray-400); padding-bottom: 1rem; margin-bottom: 1rem; font-size: 0.95rem; color: var(--success-color);"> <%# tax calculation label and value row for total accumulation %>
        <span>Tax:</span> <span>+ $14.00</span> <%# addition value for governmental compliance fees %>
      </div> <%# End of tax row %>
      <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem; font-size: 1.25rem; font-weight: 700;"> <%# final order total label and value prominently displayed %>
        <span>Total:</span> <span>$1357.97</span> <%# cumulative total cost for the current shopping session state %>
      </div> <%# End of final total row %>
      <button class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem; background: var(--success-color);">Checkout</button> <%# Primary conversion button to initiate the payment/order logic flow %>
      
      <div style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.5rem;"> <%# Grid of available payment processor icons for user trust %>
        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b5/PayPal.svg" style="height: 20px;"> <%# PayPal logo icon representation %>
        <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" style="height: 20px;"> <%# Mastercard logo icon representation %>
        <img src="https://upload.wikimedia.org/wikipedia/commons/5/5a/Visa_2021.svg" style="height: 20px;"> <%# Visa logo icon representation %>
        <img src="https://upload.wikimedia.org/wikipedia/commons/b/b0/Apple_Pay_logo.svg" style="height: 20px;"> <%# Apple Pay logo icon representation %>
      </div> <!--/ .payment-methods -->
    </div> <!--/ .order-summary -->

  </aside> <!--/ .right-column-sidebar -->

</div> <!--/ .cart-grid-layout -->

<!-- Saved for Later Section -->
<section style="margin-top: 5rem;"> <%# Secondary grid display for favorites and wishlist items as shown in the mockup area %>
  <h3 style="margin-bottom: 1.5rem;">Saved for later</h3> <%# Section header label for the wishlist preview group %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem;"> <%# Flexible item grid for non-cart products being tracked by the user session %>
    <% products.slice(0, 4).forEach(product => { %> <%# Loop through first four available products for wishlist mock representation %>
      <%- include('../partials/product-card', { product }) %> <%# Reuse the professional product-card partial component for item display consistency %>
    <% }); %> <%# End of saved products generation loop %>
  </div> <%# End of wishlist grid layout region container %>
</section> <!--/ .saved-for-later-section -->

/*
SUMMARY:
- This file implements a high-fidelity shopping cart experience based on the professional prototype mockups.
- It features a multi-column layout with detailed item controls, service trust badges, and a comprehensive order summary sidebar.
- It provides a production-ready interface that focuses on user conversion and brand consistency across desktop viewports.
*/
