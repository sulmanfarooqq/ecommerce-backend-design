<%- contentFor('body') %> <%# Start of the specific content for the user login layout %>

<div style="max-width: 400px; margin: 4rem auto; padding: 2.5rem; background: var(--white); border: 1px solid var(--gray-400); border-radius: var(--border-radius); box-shadow: var(--shadow-sm);"> <%# Centered login card container with premium spacing and subtle elevation %>
  
  <h2 style="margin-bottom: 2rem; text-align: center;">Sign in</h2> <%# Primary page heading label for user entry focus context awareness %>
  
  <form action="/auth/login" method="POST"> <%# Start of the secure login form for user credential submission %>
    
    <div style="margin-bottom: 1.5rem;"> <%# Group for user email/username identification entry logic %>
      <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Email or username</label> <%# text label for identity input control focus %>
      <input type="email" id="email" name="email" class="form-control" placeholder="Email or username" required> <%# primary identity input field with validation placeholder text %>
    </div> <%# End of identity field cluster %>

    <div style="margin-bottom: 1.5rem;"> <%# Group for secure user password entry and recovery access links %>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;"> <%# Header row for the password label and support link %>
        <label for="password" style="font-weight: 500;">Password</label> <%# label for security credential input focus %>
        <a href="#" style="font-size: 0.85rem; color: var(--primary-color);">Forgot password?</a> <%# helper link for credential recovery logic access %>
      </div> <%# End of password label row block %>
      <input type="password" id="password" name="password" class="form-control" placeholder="Type here" required> <%# masked password input field for user secrecy control %>
    </div> <%# End of password field cluster %>

    <label style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 2rem; font-size: 0.9rem; cursor: pointer;"> <%# persistent login session checkbox field choice %>
      <input type="checkbox" name="remember" style="width: 18px; height: 18px;"> Remember me <%# user toggle for prolonged authentication state persistence %>
    </label> <%# End of remember me choice label container %>

    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-bottom: 1.5rem;">Log In</button> <%# Primary action to execute the credential validation and session creation logic %>
    
    <div style="text-align: center; position: relative; margin-bottom: 1.5rem;"> <%# Visual separator for alternative authentication methods shown in mockup prototypes %>
      <hr style="border: 0; border-top: 1px solid var(--gray-400);"> <%# subtle horizontal line for visual sectioning context labels %>
      <span style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--white); padding: 0 1rem; color: var(--gray-600); font-size: 0.85rem;">OR</span> <%# decorative "OR" text overlaying the divider line from mockup area %>
    </div> <!--/ .auth-divider -->

    <div style="display: flex; flex-direction: column; gap: 0.8rem;"> <%# Block for third-party social authentication provider links matching mockup prototypes %>
      <a href="#" class="btn btn-secondary" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.8rem; font-size: 0.9rem; border-color: var(--gray-400);"> <%# Google identity provider mock link button representation %>
        <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" style="height: 18px;"> Continue with Google <%# Google branding icon and descriptive label text for the provider link %>
      </a> <%# End of Google provider link button %>
      <a href="#" class="btn btn-secondary" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.8rem; font-size: 0.9rem; background: #4267B2; color: white; border: none;"> <%# Facebook identity provider mock link button representation %>
        <i class="fab fa-facebook-f"></i> Continue with Facebook <%# Facebook branding icon and descriptive label text for the provider link %>
      </a> <%# End of Facebook provider link button %>
    </div> <!--/ .social-login-group -->

  </form> <%# End of the secure user login form container %>

  <p style="text-align: center; margin-top: 2rem; font-size: 0.95rem;"> <%# helper text to redirect unauthenticated users to registration flow context labels %>
    Don't have an account? <a href="/signup" style="color: var(--primary-color); font-weight: 600;">Register now</a> <%# Primary link to the registration page for new user creation logic %>
  </p> <%# End of registration redirect text footer group %>

</div> <!--/ .auth-card-container -->

/*
SUMMARY:
- This file implements a clean, professional login interface using the site's design tokens.
- It features a centered layout, social authentication placeholders, and clear visual hierarchy for form elements.
- It provides a production-quality entry point for authenticated users that focuses on trust and ease of use.
*/
