<%- contentFor('body') %>

<div style="max-width: 400px; margin: 4rem auto; padding: 2.5rem; background: var(--white); border: 1px solid var(--gray-400); border-radius: var(--border-radius); box-shadow: var(--shadow-sm);">

  <h2 style="margin-bottom: 2rem; text-align: center;">Sign in</h2>

  <form action="/auth/login" method="POST">

    <div style="margin-bottom: 1.5rem;">
      <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Email or username</label>
      <input type="email" id="email" name="email" class="form-control" placeholder="Email or username" required>
    </div>

    <div style="margin-bottom: 1.5rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
        <label for="password" style="font-weight: 500;">Password</label>
        <a href="#" style="font-size: 0.85rem; color: var(--primary-color);">Forgot password?</a>
      </div>
      <input type="password" id="password" name="password" class="form-control" placeholder="Type here" required>
    </div>

    <label style="display: flex; align-items: center; gap: 0.8rem; margin-bottom: 2rem; font-size: 0.9rem; cursor: pointer;">
      <input type="checkbox" name="remember" style="width: 18px; height: 18px;"> Remember me
    </label>

    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-bottom: 1.5rem;">Log In</button>

    <div style="text-align: center; position: relative; margin-bottom: 1.5rem;">
      <hr style="border: 0; border-top: 1px solid var(--gray-400);">
      <span style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--white); padding: 0 1rem; color: var(--gray-600); font-size: 0.85rem;">OR</span>
    </div>

    <div style="display: flex; flex-direction: column; gap: 0.8rem;">
      <a href="#" class="btn btn-secondary" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.8rem; font-size: 0.9rem; border-color: var(--gray-400);">
        <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" style="height: 18px;"> Continue with Google
      </a>
      <a href="#" class="btn btn-secondary" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.8rem; font-size: 0.9rem; background: #4267B2; color: white; border: none;">
        <i class="fab fa-facebook-f"></i> Continue with Facebook
      </a>
    </div>

  </form>

  <p style="text-align: center; margin-top: 2rem; font-size: 0.95rem;">
    Don't have an account? <a href="/signup" style="color: var(--primary-color); font-weight: 600;">Register now</a>
  </p>

</div>

/*
SUMMARY:
- This file implements a clean, professional login interface using the site's design tokens.
- It features a centered layout, social authentication placeholders, and clear visual hierarchy for form elements.
- It provides a production-quality entry point for authenticated users that focuses on trust and ease of use.
*/

