<%- contentFor('body') %>

<div style="max-width: 400px; margin: 4rem auto; padding: 2.5rem; background: var(--white); border: 1px solid var(--gray-400); border-radius: var(--border-radius); box-shadow: var(--shadow-sm);">

  <h2 style="margin-bottom: 2rem; text-align: center;">Register</h2>

  <form action="/auth/signup" method="POST">

    <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem;">
      <div style="flex: 1;">
        <label for="firstName" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">First name</label>
        <input type="text" id="firstName" name="firstName" class="form-control" placeholder="Type here">
      </div>
      <div style="flex: 1;">
        <label for="lastName" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Last name</label>
        <input type="text" id="lastName" name="lastName" class="form-control" placeholder="Type here">
      </div>
    </div>

    <div style="margin-bottom: 1.5rem;">
      <label for="email" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Email</label>
      <input type="email" id="email" name="email" class="form-control" placeholder="example@mail.com" required>
    </div>

    <div style="margin-bottom: 1.5rem;">
      <label for="phone" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Phone</label>
      <div style="display: flex; border: 1px solid var(--gray-400); border-radius: var(--border-radius); overflow: hidden;">
        <select style="border: none; background: #f8f9fa; padding: 0.6rem; border-right: 1px solid var(--gray-400); outline: none;">
          <option>UZ +998</option>
        </select>
        <input type="tel" id="phone" name="phone" style="border: none; padding: 0.6rem; width: 100%; outline: none;" placeholder="00-000-00-00">
      </div>
    </div>

    <div style="margin-bottom: 1.5rem;">
      <label for="password" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Create password</label>
      <input type="password" id="password" name="password" class="form-control" placeholder="At least 6 characters" required>
    </div>

    <div style="margin-bottom: 2rem;">
      <label for="confirmPassword" style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Repeat password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Type here" required>
    </div>

    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 0.8rem; font-size: 1rem; margin-bottom: 1.5rem;">Register now</button>

    <label style="display: flex; align-items: flex-start; gap: 0.8rem; margin-bottom: 2rem; font-size: 0.9rem; cursor: pointer; color: var(--gray-800);">
      <input type="checkbox" name="terms" style="width: 18px; height: 18px; margin-top: 3px;" required>
      I agree with Terms and Conditions
    </label>

  </form>

  <hr style="border: 0; border-top: 1px solid var(--gray-400); margin: 2rem 0;">

  <p style="text-align: center; font-size: 0.95rem;">
    Already have an account? <a href="/login" style="color: var(--primary-color); font-weight: 600;">Log In</a>
  </p>

</div>

/*
SUMMARY:
- This file implements a clean, professional registration interface using the site's design tokens.
- It features a centered layout, multi-part form rows, and clear legal agreement checkboxes matching the mockup prototypes.
- It provides a high-quality onboarding experience that focuses on clarity and user data validation requirements.
*/

