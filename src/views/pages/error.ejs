<%- layout('layouts/main') %>

<div style="text-align: center; padding: 6rem 0;">
  <div style="font-size: 5rem; color: var(--error-color); margin-bottom: 2rem;">
    <i class="error-emoji">⚠️</i>
  </div>

  <h1 style="font-size: 3rem; margin-bottom: 1rem;">Oops! Something went wrong</h1>
  <p style="font-size: 1.2rem; color: #666; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">
    <%= message %>
  </p>

  <% if (typeof error !== 'undefined' && error.stack) { %>
    <div style="background: #f4f4f4; padding: 2rem; border-radius: 8px; text-align: left; max-width: 800px; margin: 2rem auto; overflow-x: auto;">
      <pre style="font-family: monospace; font-size: 0.9rem; color: #555;"><%= error.stack %></pre>
    </div>
  <% } %>

  <div style="margin-top: 3rem;">
    <a href="/" class="btn btn-primary">Return to Home</a>
    <a href="javascript:history.back()" class="btn" style="background: #eee; margin-left: 1rem;">Go Back</a>
  </div>
</div>

/*
SUMMARY:
- This page serves as the global error interface for catching and displaying unexpected application failures.
- It provides a user-friendly message for shoppers while optionally showing technical data for developers during testing.
- It includes multiple navigation paths to help users successfully recover from a broken state and stay engaged.
*/

