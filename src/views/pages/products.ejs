<%- contentFor('body') %>

<nav class="breadcrumbs" style="margin-bottom: 1.5rem; color: var(--gray-600); font-size: 0.9rem;">
  Home <i class="fas fa-chevron-right" style="font-size: 0.7rem; margin: 0 0.5rem;"></i>
  Clothings <i class="fas fa-chevron-right" style="font-size: 0.7rem; margin: 0 0.5rem;"></i>
  Men's wear <i class="fas fa-chevron-right" style="font-size: 0.7rem; margin: 0 0.5rem;"></i>
  <span style="color: var(--dark-color); font-weight: 500;">Summer clothing</span>
</nav>

<div class="main-grid">

<aside class="sidebar">

    <div class="card-sidebar">
      <h4 style="display: flex; justify-content: space-between; align-items: center;">Category <i class="fas fa-chevron-up"></i></h4>
      <ul class="filter-list">
        <li>Mobile accessory</li>
        <li>Electronics</li>
        <li>Smartphones</li>
        <li>Modern tech</li>
        <li style="color: var(--primary-color);">See all</li>
      </ul>
    </div>

    <div class="card-sidebar">
      <h4 style="display: flex; justify-content: space-between; align-items: center;">Brands <i class="fas fa-chevron-up"></i></h4>
      <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem;">
        <label style="display: flex; align-items: center; gap: 0.8rem; font-size: 0.95rem;"><input type="checkbox" checked> Samsung</label>
        <label style="display: flex; align-items: center; gap: 0.8rem; font-size: 0.95rem;"><input type="checkbox" checked> Apple</label>
        <label style="display: flex; align-items: center; gap: 0.8rem; font-size: 0.95rem;"><input type="checkbox"> Huawei</label>
        <label style="display: flex; align-items: center; gap: 0.8rem; font-size: 0.95rem;"><input type="checkbox" checked> Pocco</label>
        <label style="display: flex; align-items: center; gap: 0.8rem; font-size: 0.95rem;"><input type="checkbox"> Lenovo</label>
        <a href="#" style="color: var(--primary-color); font-size: 0.9rem; margin-top: 0.5rem;">See all</a>
      </div>
    </div>

    <div class="card-sidebar">
      <h4 style="display: flex; justify-content: space-between; align-items: center;">Price range <i class="fas fa-chevron-up"></i></h4>
      <div style="margin-top: 1rem;">
        <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
          <div><label style="font-size: 0.8rem; color: var(--gray-600);">Min</label><input type="number" placeholder="0" class="form-control"></div>
          <div><label style="font-size: 0.8rem; color: var(--gray-600);">Max</label><input type="number" placeholder="9999" class="form-control"></div>
        </div>
        <button class="btn btn-secondary" style="width: 100%; border-color: var(--gray-400);">Apply</button>
      </div>
    </div>

  </aside>

<main class="results-area">

<div class="section-white" style="padding: 0.8rem 1.5rem; display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
      <div><%= totalProducts %> items in <span style="font-weight: 700;">Mobile accessory</span></div>
      <div style="display: flex; align-items: center; gap: 1.5rem;">
        <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem;"><input type="checkbox"> Verified only</label>
        <select class="form-control" style="width: 120px; padding: 0.3rem;">
          <option>Featured</option>
          <option>Price: Low to High</option>
          <option>Newest</option>
        </select>
        <div style="display: flex; border: 1px solid var(--gray-500); border-radius: 4px; overflow: hidden;">
          <div style="padding: 0.4rem 0.8rem; background: var(--gray-300); border-right: 1px solid var(--gray-500); cursor: pointer;"><i class="fas fa-th"></i></div>
          <div style="padding: 0.4rem 0.8rem; cursor: pointer; color: var(--gray-600);"><i class="fas fa-list"></i></div>
        </div>
      </div>
    </div>

<div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; align-items: center;">
      <div style="border: 1px solid var(--primary-color); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.9rem;">Samsung <i class="fas fa-times" style="margin-left: 0.5rem; cursor: pointer;"></i></div>
      <div style="border: 1px solid var(--primary-color); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.9rem;">Apple <i class="fas fa-times" style="margin-left: 0.5rem; cursor: pointer;"></i></div>
      <div style="border: 1px solid var(--primary-color); padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.9rem;">Poco <i class="fas fa-times" style="margin-left: 0.5rem; cursor: pointer;"></i></div>
      <span style="color: var(--primary-color); cursor: pointer; margin-left: 0.5rem;">Clear all filter</span>
    </div>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
      <% products.forEach(product => { %>
        <%- include('../partials/product-card', { product }) %>
      <% }); %>
    </div>

<div style="display: flex; justify-content: flex-end;">
      <%- include('../partials/pagination', { currentPage, totalPages, baseUrl: '/products' }) %>
    </div>

  </main>

</div>

/*
SUMMARY:
- This file implements a sophisticated product listing page with advanced sidebar filters and item grids.
- It includes layout features like breadcrumbs, view mode toggles, and active filter management chips.
- It mirrors the professional complexity of modern ecommerce interfaces as defined by the provided prototypes.
*/

