<%- layout('layouts/main') %>

<div style="max-width: 800px; margin: 3rem auto; padding: 2.5rem; border: 1px solid #eee; border-radius: var(--border-radius); box-shadow: 0 10px 25px rgba(0,0,0,0.05);">
  <div style="margin-bottom: 2rem; border-bottom: 1px solid #eee; padding-bottom: 1rem;">
    <h2 style="font-size: 2.2rem; margin-bottom: 0.5rem;">Add New Product</h2>
    <p style="color: #666;">Provide the necessary details to list a new product in the store database.</p>
  </div>

  <% if (typeof error !== 'undefined') { %>
    <div style="background: #fdf2f2; color: var(--error-color); padding: 1rem; border-radius: 4px; border: 1px solid #fbd5d5; margin-bottom: 2rem;">
      <%= error %>
    </div>
  <% } %>

  <form action="/admin/add-product" method="POST">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <div class="form-group">
        <label class="form-label">Product Name</label>
        <input type="text" name="name" class="form-control" placeholder="e.g. Leather Jacket" required>
      </div>

      <div class="form-group">
        <label class="form-label">Price ($)</label>
        <input type="number" name="price" step="0.01" class="form-control" placeholder="0.00" required>
      </div>

      <div class="form-group">
        <label class="form-label">Category</label>
        <input type="text" name="category" class="form-control" placeholder="e.g. Apparel" required>
      </div>

      <div class="form-group">
        <label class="form-label">Brand</label>
        <input type="text" name="brand" class="form-control" placeholder="e.g. UrbanStyle" required>
      </div>

      <div class="form-group" style="grid-column: span 2;">
        <label class="form-label">Image URL</label>
        <input type="url" name="image" class="form-control" placeholder="https://example.com/image.jpg" required>
      </div>

      <div class="form-group" style="grid-column: span 2;">
        <label class="form-label">Stock Quantity</label>
        <input type="number" name="stock" class="form-control" placeholder="0" required>
      </div>

      <div class="form-group" style="grid-column: span 2;">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-control" rows="5" placeholder="Detailed product description..." required></textarea>
      </div>
    </div>

    <div style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: flex-end;">
      <a href="/products" class="btn" style="background: #eee;">Cancel</a>
      <button type="submit" class="btn btn-primary" style="padding: 10px 40px;">Save Product</button>
    </div>
  </form>
</div>

/*
SUMMARY:
- This page allows store administrators to add new products to the catalog through a secure and detailed form.
- It provides input fields for all required product attributes, including price, category, and images.
- It features a clean, professional grid layout to make the data entry process as simple and efficient as possible.
*/

