<%- contentFor('body') %>

<section class="section-white" style="padding: 1rem; border-radius: var(--border-radius); display: grid; grid-template-columns: 240px 1fr 240px; gap: 1.5rem; margin-bottom: 2rem;">

<aside class="hero-sidebar">
    <ul class="filter-list">
      <li class="active" style="background: var(--gray-300); border-radius: 6px; padding: 0.6rem 1rem;">Automobiles</li>
      <li>Clothes and wear</li>
      <li>Home interiors</li>
      <li>Computer and tech</li>
      <li>Tools, equipments</li>
      <li>Sports and outdoor</li>
      <li>Animal and pets</li>
      <li>Machinery tools</li>
      <li>More category</li>
    </ul>
  </aside>

<div class="hero-banner" style="background: #e3f0ff url('/img.jpg') no-repeat right; border-radius: 6px; padding: 3rem 2rem; position: relative; overflow: hidden;">
    <h1 style="font-size: 2.2rem; color: #1c1c1c; margin-bottom: 1rem;">Latest trending<br><span style="font-weight: 800;">Electronic items</span></h1>
    <button class="btn btn-secondary" style="border: none; padding: 0.8rem 2rem;">Learn more</button>
  </div>

<div class="hero-user-card" style="display: flex; flex-direction: column; gap: 0.8rem;">
    <div style="background: #e3f0ff; padding: 1rem; border-radius: 6px;">
      <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
        <i class="fas fa-user-circle" style="font-size: 2.5rem; color: var(--gray-500);"></i>
        <span>Hi, user let's get started</span>
      </div>
      <a href="/signup" class="btn btn-primary" style="width: 100%; margin-bottom: 0.5rem; font-size: 0.9rem;">Join now</a>
      <a href="/login" class="btn btn-secondary" style="width: 100%; font-size: 0.9rem;">Log in</a>
    </div>
    <div style="background: #f38332; color: white; padding: 1.5rem 1rem; border-radius: 6px;">
      Get US $10 off with a new supplier
    </div>
    <div style="background: #55bdc3; color: white; padding: 1.5rem 1rem; border-radius: 6px;">
      Send quotes with supplier preferences
    </div>
  </div>

</section>

<section class="section-white" style="display: flex; padding: 0; overflow: hidden; margin-bottom: 2rem;">
  <div style="padding: 1.5rem; width: 280px; border-right: 1px solid var(--gray-400);">
    <h3>Deals and offers</h3>
    <p style="color: var(--gray-600); margin-bottom: 1.5rem;">Hygiene equipments</p>
    <div class="countdown" style="display: flex; gap: 0.5rem;">
      <div style="background: var(--dark-color); color: white; padding: 0.5rem; border-radius: 4px; text-align: center; width: 45px;">04<br><small>Days</small></div>
      <div style="background: var(--dark-color); color: white; padding: 0.5rem; border-radius: 4px; text-align: center; width: 45px;">13<br><small>Hour</small></div>
      <div style="background: var(--dark-color); color: white; padding: 0.5rem; border-radius: 4px; text-align: center; width: 45px;">34<br><small>Min</small></div>
      <div style="background: var(--dark-color); color: white; padding: 0.5rem; border-radius: 4px; text-align: center; width: 45px;">56<br><small>Sec</small></div>
    </div>
  </div>
  <div style="display: flex; flex-grow: 1; justify-content: space-around; padding: 1.5rem;">
    <% products.slice(0, 5).forEach(product => { %>
      <div style="text-align: center; cursor: pointer;">
        <img src="/img.jpg" alt="deal" style="width: 120px; height: 120px; object-fit: contain; margin-bottom: 0.5rem;">
        <p style="font-size: 0.9rem; color: var(--dark-color);"><%= product.name %></p>
        <span style="background: #ffe3e3; color: var(--accent-color); padding: 0.2rem 0.5rem; border-radius: 20px; font-size: 0.8rem; font-weight: 700;">-25%</span>
      </div>
    <% }); %>
  </div>
</section>

<section style="margin-bottom: 3rem;">
  <h2 style="margin-bottom: 1.5rem;">Recommended items</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem;">
    <% products.forEach(product => { %>
      <%- include('../partials/product-card', { product }) %>
    <% }); %>
  </div>
</section>

<section style="margin-bottom: 3rem;">
  <h2 style="margin-bottom: 1.5rem;">Suppliers by region</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem;">
    <div style="display: flex; align-items: center; gap: 0.8rem;">
      <img src="https://flagcdn.com/w20/ae.png" alt="AE" style="width: 25px;">
      <div>Arabic Emirates<br><small style="color: var(--gray-600);">shopname.ae</small></div>
    </div>
    <div style="display: flex; align-items: center; gap: 0.8rem;">
      <img src="https://flagcdn.com/w20/au.png" alt="AU" style="width: 25px;">
      <div>Australia<br><small style="color: var(--gray-600);">shopname.ae</small></div>
    </div>
    <div style="display: flex; align-items: center; gap: 0.8rem;">
      <img src="https://flagcdn.com/w20/us.png" alt="US" style="width: 25px;">
      <div>United States<br><small style="color: var(--gray-600);">shopname.ae</small></div>
    </div>
    <div style="display: flex; align-items: center; gap: 0.8rem;">
      <img src="https://flagcdn.com/w20/ru.png" alt="RU" style="width: 25px;">
      <div>Russia<br><small style="color: var(--gray-600);">shopname.ru</small></div>
    </div>
    <div style="display: flex; align-items: center; gap: 0.8rem;">
      <img src="https://flagcdn.com/w20/it.png" alt="IT" style="width: 25px;">
      <div>Italy<br><small style="color: var(--gray-600);">shopname.it</small></div>
    </div>
  </div>
</section>

<section style="background: var(--gray-400); padding: 3rem; text-align: center; border-radius: var(--border-radius); border: 1px solid var(--gray-500);">
  <h2 style="margin-bottom: 0.5rem;">Subscribe on our newsletter</h2>
  <p style="color: var(--gray-800); margin-bottom: 1.5rem;">Get daily news on upcoming offers from many suppliers all over the world</p>
  <form style="display: flex; justify-content: center; gap: 0.5rem;">
    <input type="email" placeholder="Email" class="form-control" style="max-width: 300px;">
    <button class="btn btn-primary">Subscribe</button>
  </form>
</section>

/*
SUMMARY:
- This file implements a multi-section, complex home page mirroring the professional prototype design.
- It features a three-column hero section, integrated deal timers, recommended product grids, and regional categorization.
- It focuses on using the design tokens and layout grids to create a premium, production-quality entry experience for users.
*/

